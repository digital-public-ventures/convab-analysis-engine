{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json",
  "default": true,
  "MD003": {
    "style": "atx"
  },
  "MD007": {
    "indent": 2
  },
  "MD013": false,
  "MD024": {
    "siblings_only": true
  },
  "MD033": {
    "allowed_elements": [
      "details",
      "summary",
      "antml:function_calls",
      "antml:invoke",
      "antml:parameter"
    ]
  },
  "MD040": true,
  "MD041": false
}
