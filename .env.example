# Copy this file to `.env`.

# Required for the default Gemini-backed schema and analysis flow.
GEMINI_API_KEY=your-gemini-api-key

# Optional: use OpenAI instead of Gemini.
OPENAI_API_KEY=
LLM_PROVIDER=gemini

# Optional: skip attachment types that are known to be noisy.
UNSUPPORTED_ATTACHMENT_EXTENSIONS=.htm,.html
