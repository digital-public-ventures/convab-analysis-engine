# cfpb-exploration Environment Variables

# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# Application Configuration
# ============================================

# Environment (development, staging, production)
NODE_ENV=development
# or
ENVIRONMENT=development

# Application Port
PORT=8000

# Comma-separated list of attachment extensions to skip (e.g., .htm,.html)
UNSUPPORTED_ATTACHMENT_EXTENSIONS=.htm

# ============================================
# API Keys & Secrets
# ============================================

# API Authentication Token
API_TOKEN=your-secure-token-here

# Add your service-specific API keys below:
# EXAMPLE_API_KEY=
# EXAMPLE_SECRET_KEY=

# ============================================
# Database Configuration
# ============================================

# DATABASE_URL=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=

# ============================================
# External Services
# ============================================

# Add configuration for external services:
# REDIS_URL=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# ============================================
# Feature Flags
# ============================================

# Enable/disable features
# FEATURE_FLAG_EXAMPLE=false

# ============================================
# Logging & Monitoring
# ============================================

# LOG_LEVEL=info
# SENTRY_DSN=

# ============================================
# Development Tools
# ============================================

# DEBUG=false
