{
  "type": "object",
  "properties": {
    "schema_name": {
      "type": "string",
      "description": "Descriptive name for this schema"
    },
    "version": {
      "type": "string",
      "description": "Version number of the schema"
    },
    "description": {
      "type": "string",
      "description": "Brief description of what this schema captures"
    },
    "categorical_fields": {
      "type": "array",
      "description": "Discrete categories for classification",
      "items": {
        "type": "object",
        "properties": {
          "field_name": {
            "type": "string",
            "description": "Name of the categorical field"
          },
          "description": {
            "type": "string",
            "description": "What this field captures"
          },
          "suggested_values": {
            "type": "array",
            "description": "List of suggested category values",
            "items": {
              "type": "string"
            }
          },
          "allow_multiple": {
            "type": "boolean",
            "description": "Whether multiple values can be selected"
          },
          "hint": {
            "type": "string",
            "description": "Instructions for how to best make use of this field and/or avoid pitfalls"
          }
        },
        "required": ["field_name", "description", "suggested_values", "allow_multiple"]
      }
    },
    "scalar_fields": {
      "type": "array",
      "description": "Numerical rating scales from 0-10",
      "items": {
        "type": "object",
        "properties": {
          "field_name": {
            "type": "string",
            "description": "Name of the scalar field"
          },
          "description": {
            "type": "string",
            "description": "What this score measures"
          },
          "scale_min": {
            "type": "integer",
            "description": "Minimum value of the scale"
          },
          "scale_max": {
            "type": "integer",
            "description": "Maximum value of the scale"
          },
          "scale_interpretation": {
            "type": "string",
            "description": "Explanation of what the scale values mean"
          },
          "hint": {
            "type": "string",
            "description": "Instructions for how to best make use of this field and/or avoid pitfalls"
          }
        },
        "required": ["field_name", "description", "scale_min", "scale_max", "scale_interpretation"]
      }
    }
  },
  "required": ["schema_name", "version", "description", "categorical_fields", "scalar_fields"]
}
