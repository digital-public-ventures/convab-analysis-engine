{
  "type": "OBJECT",
  "properties": {
    "analyzed_complaints": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "id": {
            "type": "STRING",
            "description": "The row ID from the source CSV (first column)."
          },
          "scalar_metrics": {
            "type": "OBJECT",
            "properties": {
              "financial_loss_amount": {
                "type": "NUMBER",
                "description": "Dollar amount lost/disputed. 0.0 if not found."
              },
              "sentiment_score": {
                "type": "NUMBER",
                "description": "Composite score -1.0 (negative) to 1.0 (positive)."
              },
              "urgency_score": {
                "type": "INTEGER",
                "description": "Level of desperation,1 to 10."
              },
              "duration_of_ordeal_days": {
                "type": "INTEGER",
                "description": "Inferred days between incident start and complaint."
              },
              "interaction_count": {
                "type": "INTEGER",
                "description": "Number of times consumer contacted the company."
              }
            },
            "required": ["financial_loss_amount", "sentiment_score", "urgency_score"]
          },
          "categorical_dimensions": {
            "type": "OBJECT",
            "properties": {
              "scam_archetype": {
                "type": "STRING",
                "description": "Modus operandi (e.g., 'Pig Butchering', 'Refund Scam')."
              },
              "communication_vector": {
                "type": "STRING",
                "description": "How bad actor contacted consumer (e.g., 'Text', 'Email')."
              },
              "payment_mechanism": {
                "type": "STRING",
                "description": "Tool used to move money (e.g., 'Zelle', 'Wire')."
              },
              "company_behavior_flags": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Grievances (e.g., 'Denied Claim', 'Rude')."
              },
              "life_impact_categories": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Human cost (e.g., 'Rent Money', 'Credit Score Damage')."
              },
              "consumer_vulnerability_tags": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Demographics (e.g., 'Elderly', 'Student')."
              },
              "regulatory_issues": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Potential breaches (e.g., 'Reg E Violation')."
              }
            }
          },
          "entity_relations": {
            "type": "OBJECT",
            "properties": {
              "third_party_entities": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Non-financial companies mentioned."
              },
              "linked_financial_institutions": {
                "type": "ARRAY",
                "items": {
                  "type": "STRING"
                },
                "description": "Other banks mentioned."
              }
            }
          }
        },
        "required": ["id", "scalar_metrics", "categorical_dimensions", "entity_relations"]
      }
    }
  }
}
